{
  "name": "surprise-travel-photography",
  "version": "1.0.0",
  "description": "Sito web personale per raccogliere le fotografie dei viaggi",
  "scripts": {
    "start": "lite-server",
    "vendor": "node scripts/vendor-leaflet.js",
    "build": "node build.js",
    "lint": "npm run lint:js && npm run lint:css && npm run lint:html",
    "lint:js": "eslint \"js/**/*.js\" build.js \"scripts/**/*.js\"",
    "lint:css": "stylelint \"css/**/*.css\"",
    "lint:html": "htmlhint index.html",
    "ci": "npm run lint && npm run build"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/alessandromarcozzi92-code/PlayGround.git"
  },
  "keywords": [
    "travel",
    "photography",
    "portfolio"
  ],
  "author": "Alessandro Marcozzi",
  "license": "ISC",
  "devDependencies": {
    "eslint": "^8.57.1",
    "htmlhint": "^1.9.2",
    "lite-server": "^2.6.1",
    "stylelint": "^16.26.1",
    "stylelint-config-standard": "^36.0.1",
    "terser": "^5.39.0"
  }
}
